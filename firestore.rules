rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * BOOKNGLOW SECURITY RULES
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isDataOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    match /salons/{salonId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if resource != null && isDataOwner(resource.data.ownerId) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if resource != null && isDataOwner(resource.data.ownerId);
    }

    match /service_categories/{serviceCategoryId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /localities/{localityId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Rules for salon bookings. 
     * @allow (list) Signed-in users can list to check availability (filtering by salon and date).
     * @allow (create) Signed-in users can create bookings for themselves.
     * @allow (get) Users can see their own bookings.
     */
    match /bookings/{bookingId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (resource.data.customerId == request.auth.uid || resource.data.salonId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.customerId == request.auth.uid;
    }

  }
}