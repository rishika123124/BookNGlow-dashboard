rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile rules
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Booking rules
    // Allow reading bookings if authenticated. 
    // This supports both user dashboard history and real-time availability checks on salon pages.
    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Salons list - Publicly readable
    match /salons/{salonId} {
      allow read: if true;
    }
  }
}