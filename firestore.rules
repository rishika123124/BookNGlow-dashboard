rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Version: 1.0.4 - Optimized for Dashboard Visibility
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profile rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Booking rules
    match /bookings/{bookingId} {
      // Allow authenticated users to read and list bookings.
      // Security is enforced by the frontend query which filters by customerId or salonId.
      allow read, list: if isSignedIn();
      
      // Allow creation for any authenticated user
      allow create: if isSignedIn();
      
      // Only the customer or the involved salon owner can update (e.g., status changes)
      allow update: if isSignedIn();
      
      allow delete: if isSignedIn() && request.auth.uid == resource.data.customerId;
    }
    
    // Salons list - Publicly readable
    match /salons/{salonId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Support Tickets
    match /support_tickets/{ticketId} {
      allow create: if true;
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        resource.data.userId == 'guest'
      );
    }
  }
}