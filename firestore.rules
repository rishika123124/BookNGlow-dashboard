rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Version: 1.0.3 - Strict Ownership and Index Alignment
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profile rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Booking rules
    match /bookings/{bookingId} {
      // Allow users to list and read their own bookings (Customer or Salon Owner)
      // Note: Queries must include a .where('customerId', '==', auth.uid) filter for this to pass
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.customerId || 
        get(/databases/$(database)/documents/salons/$(resource.data.salonId)).data.ownerId == request.auth.uid
      );
      
      // Allow creation for any authenticated user (Guest or Registered)
      allow create: if isSignedIn();
      
      // Only the customer or the salon owner can update (e.g., status changes)
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.customerId || 
        get(/databases/$(database)/documents/salons/$(resource.data.salonId)).data.ownerId == request.auth.uid
      );
      
      allow delete: if isSignedIn() && request.auth.uid == resource.data.customerId;
    }
    
    // Salons list - Publicly readable
    match /salons/{salonId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Support Tickets
    match /support_tickets/{ticketId} {
      allow create: if true;
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        resource.data.userId == 'guest'
      );
    }
  }
}