rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Version: 1.0.2 - Ownership and Dashboard Fix
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSalonOwner(salonId) {
      return isSignedIn() && get(/databases/$(database)/documents/salons/$(salonId)).data.ownerId == request.auth.uid;
    }

    // User profile rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Booking rules
    match /bookings/{bookingId} {
      // Rule alignment: Users can only list/read their own bookings (Customer or Salon)
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.customerId || 
        get(/databases/$(database)/documents/salons/$(resource.data.salonId)).data.ownerId == request.auth.uid
      );
      
      // Support guest and member creation
      allow create: if true;
      
      // Only involved parties can update status or details
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.customerId || 
        get(/databases/$(database)/documents/salons/$(resource.data.salonId)).data.ownerId == request.auth.uid
      );
      
      allow delete: if isSignedIn() && request.auth.uid == resource.data.customerId;
    }
    
    // Salons list - Publicly readable
    match /salons/{salonId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Support Tickets
    match /support_tickets/{ticketId} {
      allow create: if true;
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        resource.data.userId == 'guest'
      );
    }
  }
}