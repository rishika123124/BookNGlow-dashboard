rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Version: 1.0.7 - Fixed Dashboard Listing & Support Ticket Permissions
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profile rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Booking rules
    match /bookings/{bookingId} {
      // Secure listing: Users can only see bookings where they are the customer or the involved salon owner
      // NOTE: Queries MUST filter by customerId or salonOwnerId to satisfy these rules
      allow read, list: if isSignedIn() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.salonOwnerId == request.auth.uid
      );
      
      // Allow creation for any authenticated user if they are the customer
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.customerId;
      
      // Only the customer or the involved salon owner can update
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.customerId || 
        request.auth.uid == resource.data.salonOwnerId
      );
      
      allow delete: if isSignedIn() && request.auth.uid == resource.data.customerId;
    }
    
    // Salons list - Publicly readable
    match /salons/{salonId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Support Tickets
    match /support_tickets/{ticketId} {
      // Allow anyone (guest or member) to create a ticket
      allow create: if true;
      // Allow the creator to read their own tickets
      allow read, list: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        resource.data.userId == 'guest'
      );
    }
  }
}