rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Version: 1.0.5 - Enhanced Booking Ownership & Support Rules
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profile rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Booking rules
    match /bookings/{bookingId} {
      // Secure listing: Users can only see bookings they are involved in
      // Firestore enforces this on queries: the client MUST filter by customerId or salonOwnerId
      allow read, list: if isSignedIn() && (
        request.auth.uid == resource.data.customerId || 
        request.auth.uid == resource.data.salonOwnerId
      );
      
      // Allow creation for any authenticated user
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.customerId;
      
      // Only the customer or the involved salon owner can update (e.g., status changes)
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.customerId || 
        request.auth.uid == resource.data.salonOwnerId
      );
      
      allow delete: if isSignedIn() && request.auth.uid == resource.data.customerId;
    }
    
    // Salons list - Publicly readable
    match /salons/{salonId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Support Tickets
    match /support_tickets/{ticketId} {
      allow create: if true;
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        resource.data.userId == 'guest'
      );
    }
  }
}