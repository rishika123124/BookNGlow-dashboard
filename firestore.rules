rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile rules
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Booking rules
    match /bookings/{bookingId} {
      // Authenticated users can read bookings (for listing availability or viewing history)
      allow read: if request.auth != null;
      // Authenticated users can create bookings
      allow create: if request.auth != null;
      // Users can only update or delete their own bookings
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.customerId;
    }
    
    // Salons list - Publicly readable
    match /salons/{salonId} {
      allow read: if true;
    }
  }
}