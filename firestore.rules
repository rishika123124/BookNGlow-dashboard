
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile rules
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Booking rules
    match /bookings/{bookingId} {
      // Allow authenticated users to check availability and list their own bookings
      allow read, list: if request.auth != null;
      // Allow anyone to create a booking (guest or authenticated)
      allow create: if true;
      // Allow customers to manage their own bookings
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.customerId;
    }
    
    // Salons list - Publicly readable
    match /salons/{salonId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Support Tickets - Explicitly allowing creation for all users
    match /support_tickets/{ticketId} {
      // Deployment trigger: Ensure support ticket creation is globally allowed
      allow create: if true;
      // Allow the creator or an authenticated user with matching ID to read their ticket
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || resource.data.userId == 'guest');
    }
  }
}
