rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profile rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Booking rules
    match /bookings/{bookingId} {
      // Allow any authenticated user to list and get bookings.
      // Filtering is handled by the application logic (querying by customerId or salonId).
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      
      // Allow anyone to create a booking (supports guest booking flow)
      allow create: if true;
      
      // Allow customers to manage their own bookings
      // Allow salons to update the status of bookings for their salon
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.customerId || 
        get(/databases/$(database)/documents/salons/$(resource.data.salonId)).data.ownerId == request.auth.uid
      );
      
      allow delete: if isSignedIn() && request.auth.uid == resource.data.customerId;
    }
    
    // Salons list - Publicly readable
    match /salons/{salonId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Support Tickets
    match /support_tickets/{ticketId} {
      allow create: if true;
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || resource.data.userId == 'guest');
    }
  }
}