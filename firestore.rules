rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile rules
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Booking rules
    match /bookings/{bookingId} {
      // Allow everyone (including anonymous guests) to list bookings to check availability
      allow read: if true;
      // Allow everyone to create a booking (guest or authenticated)
      allow create: if true;
      // Only the person who created the booking can update or delete it
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.customerId;
    }
    
    // Salons list - Publicly readable
    match /salons/{salonId} {
      allow read: if true;
    }
  }
}
