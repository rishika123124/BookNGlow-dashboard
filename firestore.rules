rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * BOOKNGLOW SECURITY RULES
     * Updated to ensure proper access to bookings and user profiles.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isDataOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    match /salons/{salonId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if resource != null && isDataOwner(resource.data.ownerId);
      allow delete: if resource != null && isDataOwner(resource.data.ownerId);
    }

    match /service_categories/{serviceCategoryId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /localities/{localityId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Rules for salon bookings. 
     * @allow (list) Any signed-in user can list bookings. This is necessary for checking 
     * availability (filtering by salon and date) and for users to see their own history.
     * @allow (get) Users can see specific booking details if they are the customer or the salon owner.
     * @allow (create) Signed-in users can create bookings where they are the customer.
     */
    match /bookings/{bookingId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (resource.data.customerId == request.auth.uid || resource.data.salonId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.customerId == request.auth.uid;
    }

  }
}